{
  "name": "github-pr-helper",
  "displayName": "GitHub PR Helper",
  "description": "Streamline GitHub pull request creation with AI-powered descriptions using OpenCode",
  "version": "1.2.0",
  "publisher": "kwickramasekara",
  "repository": "https://github.com/kwickramasekara/github-pr-helper",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "github",
    "pull request",
    "pr",
    "git",
    "gemini",
    "openai",
    "anthropic",
    "ai"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "githubPrHelper.createPr",
        "title": "Create Pull Request",
        "category": "GitHub PR Helper",
        "icon": "$(add)"
      },
      {
        "command": "githubPrHelper.refreshPr",
        "title": "Refresh",
        "category": "GitHub PR Helper",
        "icon": "$(refresh)"
      },
      {
        "command": "githubPrHelper.openSettings",
        "title": "Settings",
        "category": "GitHub PR Helper",
        "icon": "$(gear)"
      },
      {
        "command": "githubPrHelper.markReady",
        "title": "Mark as Ready for Review",
        "category": "GitHub PR Helper",
        "icon": "$(check)"
      },
      {
        "command": "githubPrHelper.openInGitHub",
        "title": "Open in GitHub",
        "category": "GitHub PR Helper",
        "icon": "$(link-external)"
      },
      {
        "command": "githubPrHelper.editTitle",
        "title": "Edit Title",
        "category": "GitHub PR Helper",
        "icon": "$(edit)"
      },
      {
        "command": "githubPrHelper.viewDescription",
        "title": "View/Edit Description",
        "category": "GitHub PR Helper",
        "icon": "$(open-preview)"
      },
      {
        "command": "githubPrHelper.addReviewer",
        "title": "Add Reviewer",
        "category": "GitHub PR Helper",
        "icon": "$(add)"
      },
      {
        "command": "githubPrHelper.addCopilotReviewer",
        "title": "Add Copilot Reviewer",
        "category": "GitHub PR Helper",
        "icon": "$(hubot)"
      },
      {
        "command": "githubPrHelper.removeReviewer",
        "title": "Remove Reviewer",
        "category": "GitHub PR Helper",
        "icon": "$(close)"
      },
      {
        "command": "githubPrHelper.regenerate",
        "title": "Regenerate with OpenCode",
        "category": "GitHub PR Helper",
        "icon": "$(sparkle)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "githubPrHelper.createPr",
          "when": "view == githubPrHelper.prView",
          "group": "navigation@1"
        },
        {
          "command": "githubPrHelper.refreshPr",
          "when": "view == githubPrHelper.prView",
          "group": "navigation@2"
        },
        {
          "command": "githubPrHelper.openInGitHub",
          "when": "view == githubPrHelper.prView",
          "group": "navigation@3"
        },
        {
          "command": "githubPrHelper.openSettings",
          "when": "view == githubPrHelper.prView",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "githubPrHelper.editTitle",
          "when": "view == githubPrHelper.prView && viewItem == prTitle",
          "group": "inline"
        },
        {
          "command": "githubPrHelper.viewDescription",
          "when": "view == githubPrHelper.prView && viewItem == prDescription",
          "group": "inline"
        },
        {
          "command": "githubPrHelper.addReviewer",
          "when": "view == githubPrHelper.prView && viewItem == reviewersHeader",
          "group": "inline"
        },
        {
          "command": "githubPrHelper.addCopilotReviewer",
          "when": "view == githubPrHelper.prView && viewItem == reviewersHeader",
          "group": "inline@2"
        },
        {
          "command": "githubPrHelper.removeReviewer",
          "when": "view == githubPrHelper.prView && viewItem == reviewer",
          "group": "inline"
        },
        {
          "command": "githubPrHelper.markReady",
          "when": "view == githubPrHelper.prView && viewItem == prStatusDraft",
          "group": "inline"
        },
        {
          "command": "githubPrHelper.regenerate",
          "when": "view == githubPrHelper.prView && viewItem == prDescription",
          "group": "inline@2"
        }
      ]
    },
    "configuration": {
      "title": "GitHub PR Helper",
      "properties": {
        "githubPrHelper.baseBranch": {
          "type": "string",
          "default": "main",
          "description": "Default base branch for PRs",
          "order": 1
        },
        "githubPrHelper.defaultReviewers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Default reviewers (GitHub usernames or team slugs)",
          "order": 2
        },
        "githubPrHelper.opencodeConfig": {
          "type": "object",
          "default": {},
          "description": "Optional OpenCode configuration object (e.g., {\"model\": \"anthropic/claude-sonnet-4-5\"}). Passed to the OpenCode SDK. See https://opencode.ai/docs/config for options.",
          "order": 3
        },
        "githubPrHelper.prTemplatePath": {
          "type": "string",
          "default": "",
          "description": "Path to a PR template file (relative to workspace root). If set, OpenCode will reference this template when generating the PR description. Example: .github/pull_request_template.md",
          "order": 4
        },
        "githubPrHelper.promptOnBranchPublish": {
          "type": "string",
          "enum": [
            "ask",
            "always",
            "never"
          ],
          "enumDescriptions": [
            "Ask before creating a PR when pushing a new branch",
            "Always create a PR when pushing a new branch",
            "Never prompt to create a PR"
          ],
          "default": "ask",
          "description": "Behavior when a branch is published to remote",
          "order": 5
        },
        "githubPrHelper.enableCopilotReviewer": {
          "type": "boolean",
          "default": false,
          "description": "Automatically assign GitHub Copilot as a reviewer when creating PRs",
          "order": 6
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "github-pr-helper",
          "title": "GitHub PR Helper",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "github-pr-helper": [
        {
          "id": "githubPrHelper.prView",
          "name": "Pull Request"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "githubPrHelper.prView",
        "contents": "No pull request found for this branch.\n[Create Pull Request](command:githubPrHelper.createPr)\n[Open Settings](command:githubPrHelper.openSettings)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "check-types": "tsc --noEmit",
    "package": "npm run check-types && node esbuild.mjs --production",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.27.4",
    "eslint": "^8.54.0",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.3.13",
    "marked": "^12.0.0"
  },
  "license": "MIT"
}
